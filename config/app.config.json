    { "trigger": "record.created", "action": "toast",  "message": "Record created successfully" },
    { "trigger": "record.updated", "action": "toast",  "message": "Record updated successfully" },
    { "trigger": "record.deleted", "action": "toast",  "message": "Record deleted" },
    { "trigger": "csv.imported",   "action": "toast",  "message": "CSV import complete" },
    { "trigger": "record.created", "action": "email",  "template": "new_record", "message": "A new record was created in {{entity}}" }
  ]
}
