{
  "app": {
    "name": "CRM System",
    "language": "en",
    "description": "A config-driven customer relationship management app",
    "theme": "dark",
    "version": "1.0.0"
  },
  "entities": [
    {
      "name": "contacts",
      "label": "Contacts",
      "description": "Customer contact records",
      "fields": [
        { "name": "name",     "type": "string", "label": "Full Name",     "required": true,  "placeholder": "Jane Doe" },
        { "name": "email",    "type": "email",  "label": "Email Address", "required": true,  "placeholder": "jane@example.com" },
        { "name": "phone",    "type": "string", "label": "Phone",         "required": false, "placeholder": "+1 555 000 0000" },
        { "name": "company",  "type": "string", "label": "Company",       "required": false },
        {
          "name": "status",
          "type": "enum",
          "label": "Status",
          "required": true,
          "options": ["lead", "active", "inactive", "churned"],
          "defaultValue": "lead"
        },
        { "name": "notes",    "type": "text",   "label": "Notes",         "required": false }
      ]
    },
    {
      "name": "projects",
      "label": "Projects",
      "description": "Internal project tracking",
      "fields": [
        { "name": "title",       "type": "string", "label": "Project Title", "required": true },
        { "name": "description", "type": "text",   "label": "Description",   "required": false },
        { "name": "owner",       "type": "string", "label": "Owner",         "required": true },
        { "name": "deadline",    "type": "date",   "label": "Deadline",      "required": false },
        {
          "name": "priority",
          "type": "enum",
          "label": "Priority",
          "options": ["low", "medium", "high", "critical"],
          "defaultValue": "medium"
        },
        {
          "name": "status",
          "type": "enum",
          "label": "Status",
          "options": ["planning", "active", "paused", "completed"],
          "defaultValue": "planning"
        }
      ]
    },
    {
      "name": "tasks",
      "label": "Tasks",
      "fields": [
        { "name": "title",       "type": "string", "label": "Task",          "required": true },
        { "name": "assignee",    "type": "string", "label": "Assignee",      "required": false },
        { "name": "dueDate",     "type": "date",   "label": "Due Date",      "required": false },
        { "name": "completed",   "type": "boolean","label": "Completed",     "required": false, "defaultValue": false },
        {
          "name": "priority",
          "type": "enum",
          "label": "Priority",
          "options": ["low", "medium", "high"],
          "defaultValue": "medium"
        }
      ]
    }
  ],
  "views": [
    {
      "entity": "contacts",
      "type": "table",
      "label": "All Contacts",
      "columns": ["name", "email", "company", "status"]
    },
    {
      "entity": "contacts",
      "type": "form",
      "label": "New Contact",
      "fields": ["name", "email", "phone", "company", "status", "notes"]
    },
    {
      "entity": "projects",
      "type": "table",
      "label": "Projects",
      "columns": ["title", "owner", "priority", "status", "deadline"]
    },
    {
      "entity": "projects",
      "type": "form",
      "label": "New Project",
      "fields": ["title", "description", "owner", "deadline", "priority", "status"]
    },
    {
      "entity": "tasks",
      "type": "table",
      "label": "Tasks",
      "columns": ["title", "assignee", "priority", "dueDate", "completed"]
    },
    {
      "entity": "tasks",
      "type": "form",
      "label": "New Task",
      "fields": ["title", "assignee", "dueDate", "priority", "completed"]
    }
  ],
  "labels": {
